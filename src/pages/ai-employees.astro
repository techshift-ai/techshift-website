---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQAccordion from '../components/ui/FAQAccordion.tsx';
import AnimatedSection, { AnimatedItem } from '../components/ui/AnimatedSection.tsx';
import { HeroContainer, HeroHeadline, HeroSubhead, HeroCta } from '../components/ui/HeroAnimated.tsx';
import CalendarBooking from '../components/ui/CalendarBooking.astro';
import {
  Bot, Calendar, Package, Send, Phone, MessageSquare,
  Building2, UtensilsCrossed, Briefcase, Stethoscope,
  CheckCircle, X, ChevronRight,
} from 'lucide-react';
import type { FAQPage, WithContext } from 'schema-dts';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://techshift.ai/' },
    { '@type': 'ListItem', position: 2, name: 'AI employees', item: 'https://techshift.ai/ai-employees' },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI Employees — Customer-facing AI agents',
  description:
    'AI agents that handle customer calls, booking, order tracking, and lead follow-up 24/7 using your pricing, policies, and tone.',
  provider: {
    '@type': 'Organization',
    name: 'Techshift',
    url: 'https://techshift.ai',
  },
  serviceType: 'AI Consulting',
  areaServed: {
    '@type': 'Country',
    name: 'Canada',
  },
};

const faqItems = [
  {
    question: 'Which channels can an AI employee cover?',
    answer:
      'Most setups include chat on your website, messaging apps your customers already use, and optional voice on phone calls — depending on your workflows and compliance needs. During the first call we map which channels matter most.',
  },
  {
    question: 'How does it learn our pricing and policies?',
    answer:
      'We train the agent on your real materials: service menus, FAQs, scripts your staff uses, hours, coverage areas, and cancellation rules. It answers from your playbook — not generic guesses.',
  },
  {
    question: 'What happens when someone asks something tricky?',
    answer:
      'We define escalation paths — transfer to a person, take a message with context, or schedule a callback. You decide what \"handled\" looks like for edge cases.',
  },
  {
    question: 'Can it book appointments on our calendar?',
    answer:
      'Yes, when we connect your scheduling tool or calendar rules. It checks availability, collects what you need for the booking, and confirms automatically.',
  },
  {
    question: 'Will customers know they are talking to AI?',
    answer:
      'We follow disclosure practices appropriate to your industry and region. Most businesses prefer clear, plain-language framing so trust stays high.',
  },
  {
    question: 'Who keeps it running after launch?',
    answer:
      'The monthly subscription covers monitoring, tuning after real conversations, model upgrades when helpful, and small workflow tweaks as your business changes.',
  },
  {
    question: 'How is this different from a basic chatbot?',
    answer:
      'A basic widget answers FAQs. These agents take actions — book, update orders, capture structured leads, route issues — using integrations into the tools you already run.',
  },
  {
    question: 'How long until we go live?',
    answer:
      'Depends on channels and integrations, but we ship weekly demos so you see progress. Straightforward chat-first agents often reach pilot faster than full phone stacks.',
  },
];

const faqSchema: WithContext<FAQPage> = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question' as const,
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer' as const,
      text: item.answer,
    },
  })),
};

const agentCapabilities = [
  {
    icon: 'Phone',
    title: 'Calls and voice',
    description:
      'Answer inbound calls with consistent messaging, capture intent, and route or book instead of losing people to voicemail.',
  },
  {
    icon: 'MessageSquare',
    title: 'Chat and messaging',
    description:
      'Meet customers where they message — web chat or apps — with the same guardrails and business facts everywhere.',
  },
  {
    icon: 'Calendar',
    title: 'Booking and changes',
    description:
      'Checks availability, confirms appointments, handles common reschedule asks, and writes back to your calendar or ops system.',
  },
  {
    icon: 'Package',
    title: 'Order status and logistics',
    description:
      'Looks up orders, shares tracking updates, and gathers missing details so your team spends less time on repeat lookups.',
  },
  {
    icon: 'Send',
    title: 'Lead follow-up',
    description:
      'Responds within minutes with the next step — qualification questions, booking links, or a warm handoff with context.',
  },
  {
    icon: 'Bot',
    title: 'Grounded answers',
    description:
      'Trained on your services, fees, areas served, and policies so replies stay accurate instead of generic.',
  },
];

const useCases = [
  {
    icon: 'Building2',
    industry: 'Home services',
    title: 'After-hours calls become booked jobs',
    before:
      'Dispatch voicemail piled up after 5 PM. Callers hung up when nobody picked up, and morning callbacks meant playing phone tag.',
    after:
      'The agent answers common pricing and availability questions, qualifies the job type, and books straight into the calendar with reminders.',
    metric: 'Fewer missed evening calls and faster time-to-booked appointment.',
  },
  {
    icon: 'Stethoscope',
    industry: 'Health & wellness',
    title: 'Front desk phone load drops',
    before:
      'Staff answered the same scheduling and insurance-primer questions dozens of times a day while patients waited on hold.',
    after:
      'Routine requests flow through chat and voice with scripted compliance boundaries; staff handles exceptions only.',
    metric: 'More reliable intake data and less queue time for callers who need a human.',
  },
  {
    icon: 'Briefcase',
    industry: 'Professional services',
    title: 'Every inquiry arrives pre-qualified',
    before:
      'Web leads hit a generic inbox with half the fields missing; coordinators chased details before anyone senior reviewed.',
    after:
      'The agent asks the scope questions you define, captures documents when needed, and hands off a structured summary.',
    metric: 'Less back-and-forth and quicker routing to the right person.',
  },
  {
    icon: 'UtensilsCrossed',
    industry: 'Hospitality',
    title: 'Orders and catering requests stay organized',
    before:
      'DMs, phone calls, and email threads mixed together; catering asks stalled when the manager was on the floor.',
    after:
      'One conversational flow collects headcount, date, dietary notes, and budget — then notifies the right runner.',
    metric: 'Fewer dropped threads and cleaner handoffs to the kitchen or events team.',
  },
];

const comparisonItems = [
  { old: 'Voicemail roulette after hours', modern: 'Answers and qualifies around the clock' },
  { old: 'Staff repeating the same script', modern: 'Consistent answers from your approved facts' },
  { old: 'Leads sit until Monday', modern: 'Instant acknowledgment with next-step booking or forms' },
  { old: 'Chat widget that only apologizes', modern: 'Takes actions via your integrations' },
  { old: 'Phone tree nobody finishes', modern: 'Natural questions with smart routing' },
  { old: 'Spreadsheets for order lookups', modern: 'Live status pulled from your systems' },
];

const includedItems = [
  'Discovery on channels, scripts, and escalation rules',
  'Training content from your real policies and FAQs',
  'Integrations with calendar, CRM, or ops tools as scoped',
  'Chat and messaging flows with brand-appropriate tone',
  'Optional voice workflows where it fits',
  'Monitoring, tuning, and improvements after launch',
  'Weekly demos during the build so you see progress',
];

const iconMap: Record<string, typeof Bot> = {
  Bot, Calendar, Package, Send, Phone, MessageSquare,
  Building2, UtensilsCrossed, Briefcase, Stethoscope,
};
---

<BaseLayout
  title="AI Employees | Techshift"
  description="AI agents that handle customer calls, booking, order tracking, and lead follow-up around the clock — trained on your business."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="relative bg-surface-brand overflow-hidden" aria-labelledby="hero-heading">
    <div class="absolute inset-0 opacity-[0.06]" aria-hidden="true">
      <div class="absolute top-1/4 -left-20 w-80 h-80 rounded-full border-2 border-white"></div>
      <div class="absolute bottom-1/3 -right-10 w-60 h-60 rounded-full border-2 border-white"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-white"></div>
    </div>

    <div class="relative mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-12 pt-24 sm:pt-32 lg:pt-40 pb-16 sm:pb-20 lg:pb-24">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-body-sm text-primary-200">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li aria-hidden="true"><ChevronRight size={14} /></li>
          <li class="text-white font-medium">AI employees</li>
        </ol>
      </nav>

      <HeroContainer client:load className="max-w-3xl">
        <HeroHeadline client:load>
          <h1 id="hero-heading" class="text-display-2xl font-bold text-white leading-[1.05] tracking-[-0.03em]">
            Hire capacity without adding headcount.
          </h1>
        </HeroHeadline>
        <HeroSubhead client:load className="mt-6">
          <p class="text-body-lg sm:text-[1.25rem] text-primary-100 leading-relaxed max-w-[55ch]">
            AI employees answer inquiries, book appointments, track orders, and follow up on leads — using your pricing and policies, every hour of the day.
          </p>
        </HeroSubhead>
        <HeroCta client:load className="mt-10 flex flex-col sm:flex-row gap-4">
          <Button variant="inverse" size="lg" href="#book-ai-employees">
            Book a free consultation
            <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </Button>
          <Button variant="ghost" size="lg" href="#capabilities" class="!text-white/90 hover:!text-white hover:!bg-white/10">
            See what they handle
          </Button>
        </HeroCta>
      </HeroContainer>
    </div>
  </section>

  <section class="bg-surface-default py-16 sm:py-20 lg:py-24" aria-labelledby="problem-heading">
    <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-12">
      <AnimatedSection client:visible>
        <div class="max-w-3xl">
          <p class="text-overline font-semibold text-primary-600 uppercase tracking-[0.08em]">The gap</p>
          <h2 id="problem-heading" class="mt-2 text-display-lg font-bold text-text-primary tracking-[-0.02em]">
            Customers expect instant answers
          </h2>
          <p class="mt-4 text-body-lg text-text-secondary leading-relaxed">
            Most teams cannot staff phones and chat every night and weekend. Missed calls become missed revenue; slow replies send people to the next business on the list. AI employees fill that gap without asking anyone to work double shifts.
          </p>
        </div>
      </AnimatedSection>

      <AnimatedSection client:visible variant="stagger" className="mt-12 lg:mt-16 grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <AnimatedItem client:visible className="p-6 lg:p-8 bg-surface-subtle border border-border-default rounded-lg">
          <p class="text-display-md font-extrabold text-primary-600">24/7</p>
          <p class="mt-2 text-heading-md font-semibold text-text-primary">Coverage window</p>
          <p class="mt-2 text-body-sm text-text-secondary leading-relaxed">
            Buyers compare businesses while cooking dinner. Being available when they reach out changes who gets the job.
          </p>
        </AnimatedItem>

        <AnimatedItem client:visible className="p-6 lg:p-8 bg-surface-subtle border border-border-default rounded-lg">
          <p class="text-display-md font-extrabold text-primary-600">Minutes</p>
          <p class="mt-2 text-heading-md font-semibold text-text-primary">To first reply</p>
          <p class="mt-2 text-body-sm text-text-secondary leading-relaxed">
            Fast acknowledgment beats perfect prose. These agents respond immediately with accurate next steps tied to your playbook.
          </p>
        </AnimatedItem>

        <AnimatedItem client:visible className="p-6 lg:p-8 bg-surface-subtle border border-border-default rounded-lg">
          <p class="text-display-md font-extrabold text-primary-600">One brain</p>
          <p class="mt-2 text-heading-md font-semibold text-text-primary">Across channels</p>
          <p class="mt-2 text-body-sm text-text-secondary leading-relaxed">
            The same facts on chat, messaging, and voice — fewer contradictions and fewer frustrated repeats from customers.
          </p>
        </AnimatedItem>
      </AnimatedSection>
    </div>
  </section>

  <section id="capabilities" class="bg-surface-muted py-16 sm:py-20 lg:py-24" aria-labelledby="capabilities-heading">
    <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-12">
      <AnimatedSection client:visible>
        <p class="text-overline font-semibold text-primary-600 uppercase tracking-[0.08em]">What they do</p>
        <h2 id="capabilities-heading" class="mt-2 text-display-lg font-bold text-text-primary tracking-[-0.02em]">
          Front-office work, automated with judgment
        </h2>
        <p class="mt-4 text-body-lg text-text-secondary max-w-[60ch] leading-relaxed">
          These are not canned greeting bots. When scoped correctly, they complete tasks your customers ask for every day — bookings, updates, and structured requests — with escalation paths when a human should step in.
        </p>
      </AnimatedSection>

      <AnimatedSection client:visible variant="stagger" className="mt-12 lg:mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {agentCapabilities.map((feature) => {
          const IconComponent = iconMap[feature.icon];
          return (
            <AnimatedItem client:visible className="bg-white border border-border-default rounded-lg p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all">
              <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-primary-50 text-primary-600 mb-4">
                {IconComponent && <IconComponent size={28} />}
              </div>
              <h3 class="text-heading-md font-semibold text-text-primary">{feature.title}</h3>
              <p class="mt-2 text-body-sm text-text-secondary leading-relaxed">{feature.description}</p>
            </AnimatedItem>
          );
        })}
      </AnimatedSection>
    </div>
  </section>

  <section id="use-cases" class="bg-surface-default py-16 sm:py-20 lg:py-24" aria-labelledby="use-cases-heading">
    <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-12">
      <AnimatedSection client:visible>
        <p class="text-overline font-semibold text-primary-600 uppercase tracking-[0.08em]">Examples</p>
        <h2 id="use-cases-heading" class="mt-2 text-display-lg font-bold text-text-primary tracking-[-0.02em]">
          Where teams deploy AI employees first
        </h2>
        <p class="mt-4 text-body-lg text-text-secondary max-w-[60ch] leading-relaxed">
          The pattern is simple: start with the conversations that happen every week, tie them to your calendar or CRM, and expand once the playbook proves stable.
        </p>
      </AnimatedSection>

      <div class="mt-12 lg:mt-16 space-y-6 lg:space-y-8">
        {useCases.map((useCase) => {
          const IconComponent = iconMap[useCase.icon];
          return (
            <AnimatedSection client:visible className="bg-surface-subtle border border-border-default rounded-lg overflow-hidden">
              <div class="p-6 lg:p-8">
                <div class="flex items-center gap-3 mb-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary-50 text-primary-600">
                    {IconComponent && <IconComponent size={22} />}
                  </div>
                  <span class="text-caption font-semibold text-primary-600 uppercase tracking-widest">{useCase.industry}</span>
                </div>
                <h3 class="text-heading-lg font-semibold text-text-primary">{useCase.title}</h3>
                <div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6">
                  <div>
                    <p class="text-caption font-semibold text-text-muted uppercase tracking-widest mb-1.5">Before</p>
                    <p class="text-body-md text-text-secondary leading-relaxed">{useCase.before}</p>
                  </div>
                  <div>
                    <p class="text-caption font-semibold text-text-muted uppercase tracking-widest mb-1.5">After</p>
                    <p class="text-body-md text-text-secondary leading-relaxed">{useCase.after}</p>
                  </div>
                  <div class="lg:pl-4 lg:border-l lg:border-border-default">
                    <p class="text-caption font-semibold text-state-success uppercase tracking-widest mb-1.5">Impact</p>
                    <p class="text-body-md text-text-primary font-medium leading-relaxed">{useCase.metric}</p>
                  </div>
                </div>
              </div>
            </AnimatedSection>
          );
        })}
      </div>
    </div>
  </section>

  <section class="bg-surface-subtle py-16 sm:py-20 lg:py-24" aria-labelledby="upgrade-heading">
    <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-12">
      <AnimatedSection client:visible>
        <div class="text-center max-w-2xl mx-auto">
          <p class="text-overline font-semibold text-primary-600 uppercase tracking-[0.08em]">Comparison</p>
          <h2 id="upgrade-heading" class="mt-2 text-display-lg font-bold text-text-primary tracking-[-0.02em]">
            Manual front desk vs. AI employee
          </h2>
          <p class="mt-4 text-body-lg text-text-secondary leading-relaxed">
            Side by side, the operational difference is measurable — fewer dropped conversations and cleaner data handed to your team.
          </p>
        </div>
      </AnimatedSection>

      <AnimatedSection client:visible className="mt-12 lg:mt-16 max-w-4xl mx-auto">
        <div class="hidden sm:grid grid-cols-2 gap-4 mb-6">
          <div class="flex items-center gap-2 text-heading-md font-semibold text-text-muted">
            <X size={20} className="text-state-error" />
            Typical setup
          </div>
          <div class="flex items-center gap-2 text-heading-md font-semibold text-primary-600">
            <CheckCircle size={20} className="text-state-success" />
            With Techshift
          </div>
        </div>

        <div class="space-y-3">
          {comparisonItems.map((item) => (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 p-4 sm:p-5 bg-white border border-border-default rounded-lg">
              <div class="flex items-start gap-3">
                <X size={18} className="shrink-0 text-state-error mt-0.5 hidden sm:block" />
                <div>
                  <span class="sm:hidden text-caption font-semibold text-state-error uppercase tracking-widest">Typical: </span>
                  <span class="text-body-md text-text-secondary">{item.old}</span>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <CheckCircle size={18} className="shrink-0 text-state-success mt-0.5 hidden sm:block" />
                <div>
                  <span class="sm:hidden text-caption font-semibold text-state-success uppercase tracking-widest">Techshift: </span>
                  <span class="text-body-md text-text-primary font-medium">{item.modern}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </AnimatedSection>
    </div>
  </section>

  <section id="whats-included" class="bg-surface-default py-16 sm:py-20 lg:py-24" aria-labelledby="included-heading">
    <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-12">
      <AnimatedSection client:visible>
        <div class="text-center max-w-2xl mx-auto">
          <p class="text-overline font-semibold text-primary-600 uppercase tracking-[0.08em]">What&apos;s included</p>
          <h2 id="included-heading" class="mt-2 text-display-lg font-bold text-text-primary tracking-[-0.02em]">
            Built like a product, not a weekend script
          </h2>
          <p class="mt-4 text-body-lg text-text-secondary leading-relaxed">
            Scope varies by channel and integrations, but every engagement includes training on your facts, production rollout, and ongoing improvement.
          </p>
        </div>
      </AnimatedSection>

      <AnimatedSection client:visible variant="stagger" className="mt-12 lg:mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-4 max-w-4xl mx-auto">
        {includedItems.map((item) => (
          <AnimatedItem client:visible className="flex items-start gap-3 py-2">
            <CheckCircle size={20} className="shrink-0 text-state-success mt-0.5" />
            <span class="text-body-md text-text-primary">{item}</span>
          </AnimatedItem>
        ))}
      </AnimatedSection>

      <AnimatedSection client:visible className="mt-12 text-center">
        <Button variant="primary" size="lg" href="#book-ai-employees">
          Talk through your use case
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </Button>
      </AnimatedSection>
    </div>
  </section>

  <section id="ai-employees-faq" class="bg-surface-subtle py-16 sm:py-20 lg:py-24" aria-labelledby="ai-employees-faq-heading">
    <div class="mx-auto max-w-[800px] px-4 sm:px-6 lg:px-12">
      <AnimatedSection client:visible>
        <div class="text-center">
          <p class="text-overline font-semibold text-primary-600 uppercase tracking-[0.08em]">FAQ</p>
          <h2 id="ai-employees-faq-heading" class="mt-2 text-display-lg font-bold text-text-primary tracking-[-0.02em]">
            Questions about AI employees
          </h2>
          <p class="mt-4 text-body-lg text-text-secondary leading-relaxed">
            What operators ask before rolling out customer-facing automation.
          </p>
        </div>
      </AnimatedSection>

      <div class="mt-10 lg:mt-12">
        <FAQAccordion items={faqItems} client:visible />
      </div>
    </div>
  </section>

  <section id="book-ai-employees" class="bg-surface-brand py-16 sm:py-20 lg:py-24" aria-labelledby="ai-employees-cta-heading">
    <div class="mx-auto max-w-[800px] px-4 sm:px-6 lg:px-12 text-center">
      <AnimatedSection client:visible>
        <h2 id="ai-employees-cta-heading" class="text-display-md font-bold text-white tracking-[-0.015em]">
          Ready to cover the conversations you are missing?
        </h2>
        <p class="mt-4 text-body-lg text-primary-100 leading-relaxed max-w-[50ch] mx-auto">
          A free consultation maps channels, integrations, and escalation rules — no pitch deck, no obligation.
        </p>
        <div class="mt-8">
          <CalendarBooking />
        </div>
        <p class="mt-6 text-body-sm text-primary-200">
          Or email us directly at <a href="mailto:info@techshift.ai" class="underline underline-offset-2 hover:text-white transition-colors">info@techshift.ai</a>
        </p>
      </AnimatedSection>
    </div>
  </section>
</BaseLayout>
