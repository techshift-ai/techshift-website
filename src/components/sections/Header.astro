---
import MobileMenu from './MobileMenu.tsx';

const navItems = [
  { label: 'Services', href: '#services' },
  { label: 'How We Work', href: '#process' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-white/95 backdrop-blur-md transition-shadow"
>
  <nav
    class="mx-auto max-w-[1280px] flex items-center justify-between px-4 sm:px-6 lg:px-12 h-[72px]"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0" aria-label="Techshift AI Consulting — Home">
      <img
        src="/assets/logo-horizontal-primary.png"
        alt="Techshift AI Consulting"
        class="h-9 w-auto"
        width="160"
        height="36"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-body-md font-medium text-text-secondary hover:text-text-primary transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href="#book"
        class="inline-flex items-center justify-center h-9 px-4 py-2 text-body-sm font-medium rounded-md bg-action-primary text-white shadow-sm hover:bg-action-primary-hover hover:shadow-md hover:-translate-y-px active:bg-action-primary-active active:translate-y-0 transition-all focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
      >
        Book a call
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <MobileMenu navItems={navItems} client:load />
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (header) {
      if (currentScroll > 10) {
        header.classList.add('shadow-sm', 'border-b', 'border-border-default');
      } else {
        header.classList.remove('shadow-sm', 'border-b', 'border-border-default');
      }
    }
    lastScroll = currentScroll;
  });
</script>
